# ============================================
# DATABASE CONFIGURATION
# ============================================
# Use a URL do banco de dados gerenciado do Easypanel
# ou um banco externo
DATABASE_URL=postgresql://usuario:senha@seu-postgres-host:5432/twenty_crm
PG_DATABASE_URL=postgresql://usuario:senha@seu-postgres-host:5432/twenty_crm

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=production
NODE_PORT=3000
APP_SECRET=gerar_uma_string_aleatoria_segura_com_openssl_rand_base64_32

# ============================================
# URLS
# ============================================
FRONTEND_URL=https://seu-dominio.com
SERVER_URL=https://seu-dominio.com/api

# ============================================
# STORAGE CONFIGURATION
# ============================================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=.local-storage

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
EMAIL_DRIVER=logger
# EMAIL_SMTP_HOST=smtp.seu-servidor.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=seu-email@seu-servidor.com
# EMAIL_SMTP_PASSWORD=sua-senha
# EMAIL_FROM_ADDRESS=noreply@seu-dominio.com
# EMAIL_FROM_NAME=Twenty CRM

# ============================================
# FEATURES
# ============================================
IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=false
AUTH_PASSWORD_ENABLED=true
IS_MULTIWORKSPACE_ENABLED=true

# ============================================
# LOGGING
# ============================================
LOGGER_DRIVER=console
LOG_LEVELS=error,warn
ORM_QUERY_LOGGING=disabled

# ============================================
# REDIS (Optional - para melhor performance)
# ============================================
# REDIS_URL=redis://seu-redis-host:6379

# ============================================
# DOMAIN CONFIGURATION
# ============================================
DOMAIN=seu-dominio.com
